# Generated
Riff.xcodeproj/

# MetricKit crash + perf payloads. They live under
# ~/Library/Application Support/Riff/diagnostics; this guard is for
# the off-chance someone copies one into the repo for analysis.
# Pattern is `*.ips` / `*.crash` only (NOT a `diagnostics/` directory
# pattern) because macOS's case-insensitive filesystem otherwise
# matches our `Sources/Diagnostics/` source directory and silently
# excludes DiagnosticsCenter.swift from `git add`.
*.crash
*.ips

# Release artifacts
*.dmg
*.zip
release/

# Sparkle private signing key — public key is in Info.plist (and is
# meant to be public); the private key NEVER goes near the repo.
sparkle_eddsa_priv*
